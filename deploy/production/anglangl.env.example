DJANGO_SECRET_KEY=replace-with-production-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=anglangl.thesysm.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://anglangl.thesysm.com
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_LOG_DIR=/logs/anglangl
DJANGO_LOG_LEVEL=INFO
DJANGO_TIME_ZONE=Asia/Seoul
DJANGO_SECURE_SSL_REDIRECT=true

# Preferred production database
POSTGRES_DB=anglangl
POSTGRES_USER=cskang
POSTGRES_PASSWORD=replace-with-db-password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Optional fallback for single-host deployment
# USE_SQLITE=1
# SQLITE_NAME=db.sqlite3

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

STATIC_URL=/static/
STATIC_ROOT=/home/cskang/ganzskang/anglangl/staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=/home/cskang/ganzskang/anglangl/media

DJANGO_INTERNAL_API_TOKEN=replace-with-strong-token
INTERNAL_PLAYBACK_LINK_TTL_SECONDS=900

THEPEACH_AUTH_BASE_URL=http://127.0.0.1
THEPEACH_LOGIN_BASE_URL=http://127.0.0.1
THEPEACH_UPSTREAM_HOST_HEADER=thepeach.thesysm.com
